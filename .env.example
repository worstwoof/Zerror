APP_NAME=Cuoti DouDui Backend
APP_VERSION=0.1.0
DEBUG=false
DATABASE_URL=postgresql+psycopg://postgres:change_me@your_tencent_cloud_host:5432/zerror
AUTH_SESSION_DAYS=30
TENCENT_COS_SECRET_ID=your_tencent_cos_secret_id
TENCENT_COS_SECRET_KEY=your_tencent_cos_secret_key
TENCENT_COS_REGION=ap-shanghai
TENCENT_COS_BUCKET=your-bucket-name-1250000000
TENCENT_COS_BASE_URL=

VIVO_API_KEY=your_vivo_api_key
VIVO_APP_ID=your_vivo_app_id
VIVO_API_BASE_URL=https://api-ai.vivo.com.cn/v1
VIVO_OCR_URL=https://api-ai.vivo.com.cn/ocr/general_recognition
VIVO_TEXT_MODEL=Doubao-Seed-2.0-mini
VIVO_VISION_MODEL=qwen3.5-plus
VIVO_TEXT_THINKING_MODE=auto
VIVO_VISION_THINKING_MODE=auto
VIVO_TEXT_REASONING_EFFORT=auto
VIVO_VISION_REASONING_EFFORT=auto
VIVO_QUALITY_TEXT_MODEL=qwen3.5-plus
VIVO_QUALITY_TEXT_THINKING_MODE=auto
VIVO_QUALITY_TEXT_REASONING_EFFORT=medium
VIVO_QUALITY_TIMEOUT_SECONDS=240
VIVO_QUALITY_MAX_TOKENS=4096
VIVO_ANIMATION_MODEL=qwen3.5-plus
VIVO_ANIMATION_THINKING_MODE=disabled
VIVO_ANIMATION_REASONING_EFFORT=minimal
VIVO_TIMEOUT_SECONDS=120
VIVO_VISION_TIMEOUT_SECONDS=90
VIVO_ANIMATION_TIMEOUT_SECONDS=120
VIVO_MAX_TOKENS=4096
VIVO_ANIMATION_MAX_TOKENS=3072
MANIM_MEDIA_URL_PREFIX=/static/media/manim
ANALYSIS_JOB_MAX_WORKERS=1
MANIM_RENDER_MAX_WORKERS=1
